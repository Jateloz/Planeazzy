# ================================================================
# Planeazzy v5 — .htaccess
# Place this in C:\xampp\htdocs\ (document root)
# ================================================================

Options -Indexes
ServerSignature Off

# ── PHP settings ───────────────────────────────────────────────
php_value upload_max_filesize 10M
php_value post_max_size 12M
php_value max_execution_time 60
php_value memory_limit 256M
php_flag display_errors On

# ── MIME types ──────────────────────────────────────────────────
AddType text/css                .css
AddType application/javascript  .js
AddType application/json        .json
AddType image/svg+xml           .svg

# ── Rewrite engine ──────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Block direct access to sensitive directories
  RewriteRule ^config/             - [F,L]
  RewriteRule ^services/           - [F,L]
  RewriteRule ^logs/               - [F,L]
  RewriteRule ^storage/uploads/    - [F,L]

  # Allow direct access to CSS, JS, images, PHP
  RewriteCond %{REQUEST_FILENAME} \.(css|js|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|eot)$ [NC]
  RewriteRule .* - [L]

  RewriteCond %{REQUEST_FILENAME} \.php$ [NC]
  RewriteRule .* - [L]
</IfModule>

# ── Security headers ────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Cache static assets
  <FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # Never cache PHP
  <FilesMatch "\.php$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>
</IfModule>

# ── Protect sensitive files ─────────────────────────────────────
<FilesMatch "^(config\.php|schema\.sql|\.env|composer\.lock)$">
  Order allow,deny
  Deny from all
</FilesMatch>
